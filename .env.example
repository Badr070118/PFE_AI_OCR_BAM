APP_ENV=production

# Public URL used by the browser to access Nginx (same-origin requests will hit /api/*)
PUBLIC_APP_URL=http://localhost

# PostgreSQL
POSTGRES_DB=ai_ocr_platform
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_password
POSTGRES_PORT=5432

# MySQL (Smart Parking RAG)
MYSQL_DATABASE=smart_parking
MYSQL_USER=rag_user
MYSQL_PASSWORD=rag_password
MYSQL_ROOT_PASSWORD=root_password
MYSQL_PORT=3307

# Shared database URL (services override search_path per schema)
DATABASE_URL=postgresql+psycopg://app_user:app_password@postgres:5432/ai_ocr_platform

# Schemas
OCR_DB_SCHEMA=ocr_schema
MLPDR_DB_SCHEMA=mlpdr_schema

# CORS (no wildcard in production)
# Comma-separated list. In Docker + Nginx, localhost is the nginx origin.
CORS_ALLOW_ORIGINS=http://localhost,http://127.0.0.1,http://localhost:5173,http://127.0.0.1:5173

# OCR service
OCR_SERVICE_PORT=8001
OCR_UPLOAD_DIR=/srv/service/uploads
OCR_RESULTS_DIR=/srv/service/results
LLAMA_CPP_URL=http://host.docker.internal:8081/completion
LLAMA_CPP_MODEL=local-model
LLAMA_TEMPERATURE=0.1
LLAMA_MAX_TOKENS=800
LLAMA_TOP_P=0.9
LLAMA_HTTP_TIMEOUT_SECONDS=120
LLAMA_HTTP_RETRIES=1
LLAMA_HTTP_RETRY_BACKOFF_SECONDS=0.75
LLAMA_STOP_SEQUENCES=```|</json>|<|eot_id|>
LLAMA_DEBUG=0
LLM_FALLBACK_OLLAMA=1
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=180

# MLPDR service
MLPDR_SERVICE_PORT=8002
MLPDR_DETECTION_WEIGHTS_PATH=/srv/service/weights/detection/yolov3-detection_final.weights
MLPDR_DETECTION_CFG_PATH=/srv/service/weights/detection/yolov3-detection.cfg
MLPDR_OCR_WEIGHTS_PATH=/srv/service/weights/ocr/yolov3-ocr_final.weights
MLPDR_OCR_CFG_PATH=/srv/service/weights/ocr/yolov3-ocr.cfg
ANPR_LLM_PROVIDER=ollama
ANPR_LLM_MODEL=llama3.1:8b
ANPR_LLM_TEMPERATURE=0.1
ANPR_LLM_TIMEOUT_SECONDS=3
ANPR_STREAM_DIR=/srv/service/stream

# RAG (Streamlit)
RAG_LLM_PROVIDER=auto
RAG_LLM_MODEL=gpt-4o-mini
RAG_LLM_TEMPERATURE=0.1
RAG_LLM_TIMEOUT_SECONDS=3
