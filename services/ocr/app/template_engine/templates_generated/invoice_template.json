{
  "doc_type": "invoice",
  "template_file": "invoice_template.json",
  "anchors": {
    "document_title": ["FACTURE"],
    "reference": ["Reference"],
    "invoice_date": ["Date"],
    "due_date": ["Echeance"],
    "supplier_client_block": ["FOURNISSEUR CLIENT"],
    "items_header": ["Designation Qte PU Total"],
    "totals_block": ["Total HT", "TVA 20%", "Total TTC", "Devise"],
    "payment_terms": ["CONDITIONS DE PAIEMENT", "Paiement a"]
  },
  "schema": {
    "invoice_number": "",
    "invoice_date": "",
    "due_date": "",
    "supplier_name": "",
    "supplier_address": "",
    "client_name": "",
    "client_address": "",
    "payment_terms": "",
    "currency": "MAD",
    "total_ht": "",
    "tva_20": "",
    "total_ttc": "",
    "items": []
  },
  "required_fields": ["invoice_number", "invoice_date", "total_ttc"],
  "fields_rules": {
    "invoice_number": [
      {"type": "regex", "pattern": "Reference\\s*:\\s*(INV-\\d{4}-\\d{6})"},
      {"type": "after_colon", "labels": ["Reference"]}
    ],
    "invoice_date": [
      {"type": "regex", "pattern": "Date\\s*:\\s*([0-9]{2}/[0-9]{2}/[0-9]{4})"}
    ],
    "due_date": [
      {"type": "regex", "pattern": "Echeance\\s*:\\s*([0-9]{2}/[0-9]{2}/[0-9]{4})"}
    ],
    "payment_terms": [
      {"type": "regex", "pattern": "(Paiement\\s+a\\s+[^\\n.]+(?:\\.)?)", "group": 1}
    ],
    "currency": [
      {"type": "after_colon", "labels": ["Devise"]}
    ],
    "total_ht": [
      {"type": "regex", "pattern": "Total HT\\s*:\\s*([0-9\\s.,]+\\s*MAD)"}
    ],
    "tva_20": [
      {"type": "regex", "pattern": "TVA\\s*20%\\s*:\\s*([0-9\\s.,]+\\s*MAD)"}
    ],
    "total_ttc": [
      {"type": "regex", "pattern": "Total TTC\\s*:\\s*([0-9\\s.,]+\\s*MAD)"}
    ]
  }
}
